# Forgejo standalone git server — environment configuration
# Copy this file to .env and fill in secrets before starting:
#   cp .env.example .env
#   ../forgejo_start.sh

# ============================================================
# DATA STORAGE
# ============================================================
# Host path for all Forgejo data (git repos, DB, config).
# Must be writable by the container (UID 1000 / git user).
FORGEJO_DATA_PATH=/opt/computor/forgejo

# ============================================================
# ADMIN ACCOUNT
# ============================================================
# These credentials become the Forgejo admin user.
# Also set GIT_SERVER_ADMIN_USERNAME / GIT_SERVER_ADMIN_PASSWORD
# in the main computor .env to the same values.
FORGEJO_ADMIN_USERNAME=forgejo-admin
FORGEJO_ADMIN_PASSWORD=CHANGE_ME_FORGEJO_ADMIN_PASSWORD
FORGEJO_ADMIN_EMAIL=admin@computor.local

# ============================================================
# DATABASE
# ============================================================
FORGEJO_DB_PASSWORD=CHANGE_ME_FORGEJO_DB_PASSWORD

# Port to expose Forgejo's Postgres on the host (5441 = default, avoids
# collisions with main=5432, temporal=5433, keycloak=5438, coder=5439).
FORGEJO_DB_PORT=5441

# ============================================================
# SERVER
# ============================================================
# Public port for the Forgejo web UI and API.
FORGEJO_PORT=3030

# Public hostname (used in clone URLs and OIDC redirect URIs).
FORGEJO_DOMAIN=localhost

# Full public root URL — must match FORGEJO_DOMAIN and FORGEJO_PORT.
# Dev:  http://localhost:3030
# Prod: https://git.yourdomain.com
FORGEJO_ROOT_URL=http://localhost:3030
