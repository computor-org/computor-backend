# Forgejo standalone configuration
# Copy to .env and fill in values before running start.sh

# Directory where Forgejo and its Postgres store persistent data
# Subdirectories forgejo/ and postgres/ are created automatically by Docker
FORGEJO_DATA_PATH=/opt/forgejo-data

# HTTP port exposed on the host (Forgejo web UI + API)
# Port 3000 is taken by computor-web — use 3030 or another free port
FORGEJO_HTTP_PORT=3030

# SSH port (bound to 127.0.0.1 — expose via your reverse proxy if needed)
FORGEJO_SSH_PORT=2222

# Public root URL Forgejo uses to build clone URLs and links
# Change this to your actual domain in production
FORGEJO_ROOT_URL=http://localhost:3030/
FORGEJO_DOMAIN=localhost

# Database credentials (used by both the Postgres container and Forgejo itself)
# Postgres listens internally on 5441 (5432=main, 5433=temporal, 5439=coder are taken)
FORGEJO_DB_NAME=forgejo
FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASSWORD=CHANGE_ME_FORGEJO_DB_PASSWORD
FORGEJO_POSTGRES_PORT=5441

# Disable public self-registration (users are provisioned via computor-backend)
FORGEJO_DISABLE_REGISTRATION=true

FORGEJO_LOG_LEVEL=Info

# Forgejo admin account — created by the bootstrap service on first run.
# Set the same values in the main computor .env (FORGEJO_ADMIN_USERNAME / PASSWORD).
FORGEJO_ADMIN_USERNAME=admin
FORGEJO_ADMIN_EMAIL=admin@example.com
FORGEJO_ADMIN_PASSWORD=CHANGE_ME_FORGEJO_ADMIN_PASSWORD
