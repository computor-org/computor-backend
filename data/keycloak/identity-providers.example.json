    "clientId": "computor",
    "clientSecretEnv": "IDP_EXAMPLE_CLIENT_SECRET",
    "defaultScopes": "openid email profile",
    "trustEmail": true,
    "syncMode": "FORCE",
    "mappers": {
      "email": "email",
      "givenName": "given_name",
      "familyName": "family_name"
    }
  }
]
