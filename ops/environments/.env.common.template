# Computor Platform Environment Configuration
# This is the MAIN configuration file for all services
# Copy this to .env.common and adjust values

# ============================================
# SYSTEM CONFIGURATION
# ============================================
# Host directory for all persistent data (DBs, MinIO, shared files, documents).
# setup-env.sh prompts for this; it is the host side of every bind mount.
SYSTEM_DEPLOYMENT_PATH=/opt/computor
# Container-side path: where the host's "shared" dir is mounted INSIDE the API/
# worker containers (compose mounts ${SYSTEM_DEPLOYMENT_PATH}/shared at
# ${API_ROOT_PATH}/shared). Documents read/write uses DOCUMENTS_ROOT (see below).
API_ROOT_PATH=/opt/computor
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Git configuration for workers
SYSTEM_GIT_NAME="Computor Worker"
SYSTEM_GIT_EMAIL=worker@computor.local

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Main PostgreSQL database
POSTGRES_HOST=postgres
POSTGRES_PORT=5437
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=computor
POSTGRES_EXTERNAL_PORT=5432

# Temporal PostgreSQL database (separate instance)
TEMPORAL_POSTGRES_PASSWORD=CHANGE_ME_TEMPORAL_DB_PASSWORD
TEMPORAL_POSTGRES_PORT=5433

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ============================================
# TEMPORAL CONFIGURATION
# ============================================
TEMPORAL_HOST=temporal
TEMPORAL_NAMESPACE=default
TEMPORAL_PORT=7233
TEMPORAL_EXTERNAL_PORT=7233
TEMPORAL_UI_PORT=8088

# ============================================
# MINIO OBJECT STORAGE
# ============================================
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_DEFAULT_BUCKETS=computor-storage
MINIO_REGION=us-east-1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# 20 MB in bytes
MINIO_MAX_UPLOAD_SIZE=20971520
MINIO_SECURE=false

# ============================================
# TRAEFIK CONFIGURATION
# ============================================
TRAEFIK_HTTP_PORT=8080
TRAEFIK_HTTPS_PORT=8446

# ============================================
# API CONFIGURATION
# ============================================
API_PORT=8000
# URL the Docker workers use to reach the backend (setup-env.sh sets this per env).
# Dev:  http://host.docker.internal:8000 (macOS) / http://172.17.0.1:8000 (Linux)
# Prod: http://uvicorn:8000 (backend container on computor-network)
API_URL=http://localhost:8000
# Bootstrap admin — provisioned in Keycloak on backend startup (email is the
# username), added to the 'administrators' group; the _admin role follows on
# first login. The password is applied only on initial creation — rotating it
# later in Keycloak is preserved across restarts. Requires KEYCLOAK_ENABLED=true.
API_ADMIN_EMAIL=admin@computor.local
API_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ============================================
# WEB FRONTEND (computor-web)
# ============================================
# Backend API URL exposed to the browser, baked into the web build (setup-env.sh
# sets this per env). Dev: http://localhost:8000   Prod: https://<your-domain>/api
NEXT_PUBLIC_API_URL=http://localhost:8000

# Docker build settings
COMPUTOR_WEB_IMAGE_NAME=computor-web
COMPUTOR_WEB_IMAGE_TAG=latest
COMPUTOR_WEB_REGISTRY=
COMPUTOR_WEB_PORT=3000

# ============================================
# SECURITY TOKENS
# ============================================
# Generate with: openssl rand -base64 32
TOKEN_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ============================================
# WORKER CONFIGURATION
# ============================================
# Worker replicas
TEMPORAL_WORKER_REPLICAS=1
TESTING_WORKER_REPLICAS=1

# Testing worker token
TESTING_WORKER_TOKEN=CHANGE_ME_WORKER_TOKEN

# ============================================
# MATLAB WORKER (Optional)
# ============================================
# Set to true to start the temporal-worker-matlab container (requires a
# MATLAB base image — see docker/temporal-worker-matlab/Dockerfile).
# When enabled, also add to .env:
#   MATLAB_BASE_IMAGE=matlab-base:latest
#   MATLAB_TESTING_WORKER_REPLICAS=1
#   MATLAB_WORKER_TOKEN=<openssl rand -hex 32>
#   MATLAB_TEST_ENGINE_URL=
#   MATLAB_TEST_ENGINE_TOKEN=
#   MATLAB_TEST_ENGINE_VERSION=latest
#   MATLAB_MLM_LICENSE_FILE=
MATLAB_ENABLED=false

# ============================================
# GIT SERVER CONFIGURATION (Optional)
# ============================================
# Set to the git server type to enable the /git/* API endpoints and
# include the service in startup.sh.  Supported values: forgejo, gitlab
# Leave empty to disable.
GIT_SERVER=

# URL of the git server as reachable from a locally-running backend (dev) or
# the browser. Used by the dev backend started via api.sh.
GIT_SERVER_URL=http://localhost:3030

# URL of the git server as reachable from inside Docker (container-to-container).
# Used by any service that runs in a Docker container: prod backend (uvicorn),
# temporal-workers (dev + prod). The dev backend (api.sh, runs locally) uses
# GIT_SERVER_URL instead.
GIT_SERVER_URL_INTERNAL=http://computor-forgejo:3030

# Admin credentials — used by the backend API and (for Forgejo) also by the
# bootstrap container to create the admin account on first start.
# Forgejo: set to your chosen admin username/password.
# GitLab:  username is always "root".
GIT_SERVER_ADMIN_USERNAME=forgejo-admin
GIT_SERVER_ADMIN_PASSWORD=CHANGE_ME_GIT_SERVER_ADMIN_PASSWORD

# ============================================
# FORGEJO CONFIGURATION (requires GIT_SERVER=forgejo)
# ============================================
# See computor-forgejo/.env.example for full documentation.

# Admin account email (username/password come from GIT_SERVER_ADMIN_* above)
FORGEJO_ADMIN_EMAIL=admin@computor.local

# Dedicated Postgres for Forgejo (port 5441, separate from main DB)
FORGEJO_DB_PASSWORD=CHANGE_ME_FORGEJO_DB_PASSWORD
FORGEJO_DB_PORT=5441

# Public hostname and root URL (used in clone URLs and OIDC redirect URIs)
# Dev:  FORGEJO_DOMAIN=localhost, FORGEJO_ROOT_URL=http://localhost:3030
# Prod: FORGEJO_DOMAIN=git.yourdomain.com, FORGEJO_ROOT_URL=https://git.yourdomain.com
FORGEJO_DOMAIN=localhost
FORGEJO_ROOT_URL=http://localhost:3030
FORGEJO_PORT=3030

# Traefik host-based routing (production only)
FORGEJO_TRAEFIK_ENABLED=false

# Forgejo<->Keycloak OIDC is fully automatic: when KEYCLOAK_ENABLED=true,
# startup.sh includes docker-compose.forgejo-keycloak.yaml, which creates a
# dedicated "forgejo" Keycloak client (with a generated secret) and registers
# it in Forgejo. Nothing to configure here.

# ============================================
# CODER CONFIGURATION (Optional)
# ============================================
# Set to true to enable Coder workspace management
CODER_ENABLED=false

# Coder PostgreSQL database (separate from main DB)
CODER_POSTGRES_USER=coder
CODER_POSTGRES_PASSWORD=CHANGE_ME_CODER_DB_PASSWORD

# Coder admin credentials — internal only (the backend uses them to reach the
# Coder API; not a human login). setup-env.sh generates the password and mirrors
# CODER_ADMIN_EMAIL to API_ADMIN_EMAIL when Coder is enabled.
CODER_ADMIN_USERNAME=admin
CODER_ADMIN_EMAIL=admin@example.com
CODER_ADMIN_PASSWORD=CHANGE_ME_CODER_PASSWORD

# Admin API secret for Traefik-protected endpoints (setup-env.sh generates this
# with: openssl rand -hex 32).
CODER_ADMIN_API_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# Note: Coder's server is internal-only (CODER_ACCESS_URL=http://coder:7080,
# not behind Traefik), so there is no external Coder hostname to configure.
# Only workspaces are exposed, via CODER_WORKSPACE_BASE_URL below.

# Docker configuration (auto-detected by startup.sh if empty)
DOCKER_GID=

# Registry for workspace images.
# Protected by docker-network isolation, not auth — see docker-compose.coder.yaml.
CODER_REGISTRY_PORT=5000

# Coder security settings
CODER_DISABLE_PASSWORD_AUTH=false
CODER_DISABLE_SESSION_EXPIRY_REFRESH=false
CODER_TELEMETRY_ENABLE=false

# URLs for backend integration (setup-env.sh sets these per environment)
# Dev: http://localhost:7080   Prod: http://coder:7080 (backend reaches Coder over computor-network)
CODER_URL=http://localhost:7080
# Traefik base URL for workspace access (code-server via /coder/{user}/{workspace}/)
CODER_WORKSPACE_BASE_URL=http://localhost:8080/coder
# URL Coder workspaces use to call back into the backend.
# Dev: http://host.docker.internal:8000   Prod: http://localhost:8080/api
BACKEND_EXTERNAL_URL=http://host.docker.internal:8000

# ============================================
# DOCUMENTS API
# ============================================
# Root of the documents tree. The /documents API writes here; the
# static-server container exposes the same path read-only at /docs.
DOCUMENTS_ROOT=/opt/computor/shared/documents
# Max bytes per file upload via the /documents API (default 10 MiB).
DOCUMENTS_MAX_FILE_SIZE=10485760

# ============================================
# EXTENSION CONFIGURATION
# ============================================
EXTENSION_PUBLIC_DOWNLOAD_URL=
EXTENSION_GETTING_STARTED_URL=

# ============================================
# KEYCLOAK CONFIGURATION
# ============================================
# Keycloak is the standard identity provider: bearer-token (browser/SSO) auth
# goes through Keycloak. Only API-token auth works without it.
# startup.sh includes docker-compose.keycloak.yaml when this is true.
# Set to false only if you intend to run with API-token auth exclusively.
KEYCLOAK_ENABLED=true

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN_PASSWORD
KEYCLOAK_DB_PASSWORD=CHANGE_ME_KEYCLOAK_DB_PASSWORD
KEYCLOAK_DB_PORT=5438
KEYCLOAK_PORT=8180

KEYCLOAK_REALM=computor
KEYCLOAK_CLIENT_ID=computor-backend
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_KEYCLOAK_CLIENT_SECRET

# URL the backend process uses to reach Keycloak.
# Dev (backend runs locally):    http://localhost:8180/auth
# Prod (backend in Docker):      http://computor-keycloak:8080/auth  (= KEYCLOAK_SERVER_URL_INTERNAL)
KEYCLOAK_SERVER_URL=http://localhost:8180/auth

# Internal Docker-network URL — used by the backend container and the
# forgejo-keycloak-setup service. Must be reachable from within computor-network.
KEYCLOAK_SERVER_URL_INTERNAL=http://computor-keycloak:8080/auth

# Public URL Keycloak uses for browser-facing redirect URIs and OIDC issuer.
# Dev:  http://localhost:8180  (direct port, no Traefik)
# Prod: https://yourdomain.com/auth  (behind Traefik with KEYCLOAK_HTTP_RELATIVE_PATH=/auth)
KEYCLOAK_PUBLIC_URL=http://localhost:8180

# Subpath Keycloak is mounted at (leave as / for direct-port dev access).
# Set to /auth when routing through Traefik in production.
KEYCLOAK_HTTP_RELATIVE_PATH=/

# Traefik host-based routing (production only)
KEYCLOAK_TRAEFIK_ENABLED=false

# ============================================
# DEBUG CONFIGURATION
# ============================================
DEBUG_MODE=development
DISABLE_API_DEBUG_INFO=false

# Dev-only: forward these localhost ports to host.docker.internal inside workspace containers
# Useful when workspace containers need to reach services on the host (e.g. GitLab)
# Comma-separated list of ports (empty = disabled, ignored in production)
# DEV_FORWARD_PORTS=8084