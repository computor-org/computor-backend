# Forgejo git server — add these to your main .env when GIT_SERVER=forgejo
#
# Mandatory:
GIT_SERVER=forgejo

# URL at which Forgejo is reachable FROM THE BACKEND PROCESS.
# Dev (backend runs locally): http://localhost:3030
# Prod (backend in Docker on computor-network): http://computor-forgejo:3030
GIT_SERVER_URL=http://localhost:3030

# Admin credentials — GIT_SERVER_ADMIN_* serve as both the backend API credentials
# and the Forgejo admin account (bootstrap uses them to create the admin user).
GIT_SERVER_ADMIN_USERNAME=forgejo-admin
GIT_SERVER_ADMIN_PASSWORD=CHANGE_ME

# Admin email (username/password come from GIT_SERVER_ADMIN_* above)
FORGEJO_ADMIN_EMAIL=admin@computor.local
FORGEJO_DB_PASSWORD=CHANGE_ME

# Public hostname and URL (used in clone URLs and OIDC redirect URIs)
# Dev:  localhost / http://localhost:3030
# Prod: git.yourdomain.com / https://git.yourdomain.com
FORGEJO_DOMAIN=localhost
FORGEJO_ROOT_URL=http://localhost:3030
FORGEJO_PORT=3030
FORGEJO_DB_PORT=5441

# Traefik routing (production): set to true and configure a domain
FORGEJO_TRAEFIK_ENABLED=false

# Keycloak OIDC integration.
# When KEYCLOAK_ENABLED=true, startup.sh auto-creates the Keycloak client and
# registers it in Forgejo — leave both empty for fully automatic setup.
# Override only when using an external Keycloak or a specific client ID is required.
FORGEJO_KEYCLOAK_CLIENT_ID=
FORGEJO_KEYCLOAK_CLIENT_SECRET=
