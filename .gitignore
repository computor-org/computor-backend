# But keep computor-client generated files (needed for Docker builds)
# Generated TypeScript types/clients in computor-web/src/generated/ are tracked in git

# Brokered external identity providers — real institute config is local-only,
# like .env. Commit only data/keycloak/identity-providers.example.json.
data/keycloak/identity-providers.json

# Bootstrap deployments — real service definitions (with tokens via ${env}) are
# local-only, like .env. Commit only the *.example.yaml templates.
data/deployments/*.yaml
data/deployments/*.yml
!data/deployments/*.example.yaml
!data/deployments/*.example.yml

# Next.js
computor-web/.next/
# Auto-generated by `next dev`/`next build`; its typed-routes import path flips
# between .next/dev/types and .next/types depending on the last command run.
computor-web/next-env.d.ts
computor-web/tsconfig.tsbuildinfo

# Playwright e2e artifacts
computor-web/test-results/
computor-web/playwright-report/
computor-web/.playwright/

__pycache__
.vscode
tmp/
**.egg-info/
.prefectignore
**/venv/**
**/.venv/**
start.sh
**/dist/**
**/build/**

**/node_modules/**
/.pnp
.pnp.js

/coverage

/build

.DS_Store

# Environment files (keep templates, ignore actual configs)
.env
.env.common
.env.dev
.env.prod
.env.coder
.env.local
.env.development.local
.env.test.local
.env.production.local
# Keep templates in version control
!.env.*.template

# Old environment files (for migration period)
.env.dev.old
.env.prod.old
startup.sh.old

# Coder deployment environment
ops/coder/.env

npm-debug.log*
yarn-debug.log*
yarn-error.log*

/plugins/*
!/plugins/.gitkeep
data/auth_plugins.json
