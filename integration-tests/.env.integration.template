# Integration-test environment — copy to `.env.integration` and tweak.
# Defaults are wired into docker-compose.integration.yaml, so most values
# here only need changing if ports collide on your host.

# ---- Admin / API --------------------------------------------------------
API_ADMIN_USER=admin
API_ADMIN_PASSWORD=it-admin-pass
IT_API_PORT=18000

# ---- Database -----------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=it-postgres-pass
POSTGRES_DB=computor
IT_POSTGRES_PORT=15432

# ---- Redis --------------------------------------------------------------
REDIS_PASSWORD=it-redis-pass
IT_REDIS_PORT=16379

# ---- Temporal -----------------------------------------------------------
TEMPORAL_POSTGRES_PASSWORD=temporal
IT_TEMPORAL_PORT=17233
IT_TEMPORAL_UI_PORT=18088

# ---- MinIO --------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_DEFAULT_BUCKETS=computor-storage
MINIO_MAX_UPLOAD_SIZE=20971520
IT_MINIO_API_PORT=19000
IT_MINIO_CONSOLE_PORT=19001

# ---- GitLab -------------------------------------------------------------
# Ports are deliberately different from the dev GitLab on 8084.
GITLAB_CE_VERSION=16.5.0-ce.0
GITLAB_ROOT_PASSWORD=ChangeMeIntegration1!
IT_GITLAB_HTTP_PORT=8085
IT_GITLAB_HTTPS_PORT=8444
IT_GITLAB_SSH_PORT=2224

# Populated by `make bootstrap` (scripts/bootstrap_gitlab.py) — do not set by hand.
GITLAB_ADMIN_TOKEN=

# ---- Secrets (generate with: openssl rand -base64 32) -------------------
TOKEN_SECRET=it-token-secret-change-me
AUTH_SECRET=it-auth-secret-change-me

# ---- Workers ------------------------------------------------------------
TESTING_WORKER_TOKEN=it-worker-token-change-me
PYTHON_TEST_VERSION=3.13

# ---- Misc ---------------------------------------------------------------
DEBUG_MODE=development
