# Integration-test environment — copy to `.env.integration` and tweak.
# Defaults are wired into docker-compose.integration.yaml, so most values
# here only need changing if ports collide on your host.

# ---- Admin / API --------------------------------------------------------
# API_ADMIN_EMAIL is what the backend uses to bootstrap the _admin user in
# Keycloak (group `administrators`); first SSO login grants the _admin role.
API_ADMIN_USER=admin
API_ADMIN_EMAIL=admin@integration.test
API_ADMIN_PASSWORD=it-admin-pass
IT_API_PORT=18000

# ---- Database -----------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=it-postgres-pass
POSTGRES_DB=computor
IT_POSTGRES_PORT=15432

# ---- Redis --------------------------------------------------------------
REDIS_PASSWORD=it-redis-pass
IT_REDIS_PORT=16379

# ---- Temporal -----------------------------------------------------------
TEMPORAL_POSTGRES_PASSWORD=temporal
IT_TEMPORAL_PORT=17233
IT_TEMPORAL_UI_PORT=18088

# ---- MinIO --------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_DEFAULT_BUCKETS=computor-storage
MINIO_MAX_UPLOAD_SIZE=20971520
IT_MINIO_API_PORT=19000
IT_MINIO_CONSOLE_PORT=19001

# ---- Keycloak (SSO) -----------------------------------------------------
# Realm `computor` is imported on first boot from data/keycloak/computor-realm.json
# (make env stages it into keycloak-import/ with KEYCLOAK_CLIENT_SECRET substituted
# for the PLACEHOLDER_CLIENT_SECRET). Changing these requires `make clean`.
IT_KEYCLOAK_PORT=18180
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=it-keycloak-admin-pass
KEYCLOAK_DB_PASSWORD=it-keycloak-db-pass
KEYCLOAK_REALM=computor
KEYCLOAK_CLIENT_ID=computor-backend
KEYCLOAK_CLIENT_SECRET=it-keycloak-client-secret
# Substituted into the forgejo client of the imported realm (unused in the
# integration stack — Forgejo SSO is not exercised — but the realm defines it).
FORGEJO_CLIENT_SECRET=it-forgejo-client-secret

# ---- Forgejo (git server) -----------------------------------------------
IT_FORGEJO_PORT=13030
GIT_SERVER=forgejo
GIT_SERVER_ADMIN_USERNAME=computor-admin
GIT_SERVER_ADMIN_PASSWORD=it-forgejo-admin-pass
FORGEJO_ADMIN_EMAIL=admin@computor.local
FORGEJO_DB_PASSWORD=it-forgejo-db-pass

# ---- Secrets ------------------------------------------------------------
# TOKEN_SECRET symmetrically encrypts retrievable secrets (git-server tokens)
# via keycove/Fernet, so it MUST be a valid Fernet key: 32 url-safe base64 bytes
# (44 chars). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# (NOT `openssl rand -base64 32` — that is standard, non-url-safe base64.)
TOKEN_SECRET=aW50ZWdyYXRpb24tdGVzdC10b2tlbi1zZWNyZXQtMzI=
AUTH_SECRET=it-auth-secret-change-me

# ---- Workers ------------------------------------------------------------
# MUST be `ctp_` + EXACTLY 32 url-safe base64 chars (36 total) — the API seeds
# this literal as the testing worker's ApiToken and the worker authenticates
# with the same value. validate_token_format checks the EXACT length (not >=),
# so a wrong-length token is silently rejected at auth (401) and every test run
# fails to fetch its reference — the worker looks up fine but tests never execute.
TESTING_WORKER_TOKEN=ctp_itworkertoken0000000000000000000
PYTHON_TEST_VERSION=3.13

# ---- Misc ---------------------------------------------------------------
DEBUG_MODE=development
